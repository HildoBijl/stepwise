{
  "compilerOptions": {
    "paths": {
      "@step-wise/*": ["./packages/*/src"]
    },
    "moduleResolution": "bundler",
    "module": "commonjs",
    "target": "es2019",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jest", "node"]
  }
}